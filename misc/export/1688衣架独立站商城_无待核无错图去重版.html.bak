<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>1688衣架外贸独立站商城 - 逐SKU原图价格修正版</title>
  <style>
    :root{--bg:#f6f7f8;--panel:#fff;--ink:#1d252c;--muted:#66737d;--line:#e1e7ea;--brand:#0f7478;--price:#c84d28;--soft:#e9f6f6;--warn:#8a4b00}
    *{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Arial,'Microsoft YaHei',sans-serif;background:var(--bg);color:var(--ink);letter-spacing:0;-webkit-text-size-adjust:100%}
    button,a{touch-action:manipulation}.top{position:sticky;top:0;z-index:10;background:rgba(255,255,255,.96);border-bottom:1px solid var(--line);backdrop-filter:blur(10px)}
    .bar{max-width:1440px;margin:auto;padding:14px 20px;display:flex;align-items:center;gap:14px;flex-wrap:wrap}.brand{font-size:20px;font-weight:800;margin-right:auto;white-space:nowrap}
    .nav{display:flex;gap:8px;flex-wrap:wrap}.nav button{border:1px solid var(--line);background:#fff;color:var(--ink);height:36px;padding:0 14px;border-radius:8px;cursor:pointer;font-weight:700;white-space:nowrap}.nav button.active{background:var(--brand);color:#fff;border-color:var(--brand)}
    .summary{max-width:1440px;margin:18px auto 8px;padding:0 20px;display:grid;grid-template-columns:repeat(5,minmax(120px,1fr));gap:10px}.metric{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:12px 14px}.metric strong{display:block;font-size:22px;color:var(--brand)}.metric span{font-size:12px;color:var(--muted)}
    .grid{max-width:1440px;margin:auto;padding:12px 20px 40px;display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:16px}.card{background:var(--panel);border:1px solid var(--line);border-radius:8px;overflow:hidden;display:flex;flex-direction:column;min-width:0;box-shadow:0 8px 24px rgba(20,34,44,.06)}
    .photo{position:relative;aspect-ratio:1/1;background:#fff;overflow:hidden;border-bottom:1px solid var(--line)}.photo img{width:100%;height:100%;object-fit:contain;display:block;transition:opacity .22s ease}
    .body{padding:14px;display:flex;flex-direction:column;gap:10px}.cat{font-size:12px;color:var(--brand);font-weight:800}.title{font-size:15px;line-height:1.45;font-weight:800;min-height:42px}
    .sku{font-size:12px;color:var(--muted);line-height:1.45;background:#f8fafb;border:1px solid var(--line);border-radius:6px;padding:8px}.price{font-size:23px;font-weight:900;color:var(--price)}.status{font-size:12px;color:var(--muted)}
    .sku-buttons{display:flex;gap:8px;flex-wrap:wrap;max-height:176px;overflow:auto;padding-right:2px}.sku-btn{border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px 10px;cursor:pointer;font-size:12px;max-width:100%;white-space:normal;text-align:left}.sku-btn.active{border-color:var(--brand);background:var(--soft);color:var(--brand);font-weight:800}
    .buy{display:inline-flex;align-items:center;justify-content:center;height:38px;padding:0 14px;border-radius:8px;background:var(--brand);color:#fff;text-decoration:none;font-weight:800;width:max-content}
    details{border-top:1px solid var(--line);padding-top:8px}summary{cursor:pointer;color:var(--muted);font-size:13px;font-weight:800}.detail-block{margin-top:10px;display:flex;flex-direction:column;gap:14px;max-height:520px;overflow:auto}.detail-block h4{margin:0;font-size:15px}.kv,.pkg{width:100%;border-collapse:collapse;font-size:12px;line-height:1.45}.kv th,.kv td,.pkg th,.pkg td{border:1px solid var(--line);padding:8px;vertical-align:top;word-break:break-word}.kv th,.pkg th{background:#f4f6f7;text-align:left;font-weight:800}.kv th{width:36%}.note{font-size:12px;color:var(--muted)}
    @media(max-width:760px){
      body{background:#eef2f3}.top{box-shadow:0 4px 18px rgba(22,35,45,.09)}.bar{padding:10px 12px 8px;gap:10px}.brand{width:100%;font-size:17px;line-height:1.2}
      .nav{width:calc(100% + 24px);margin:0 -12px;padding:0 12px 2px;overflow-x:auto;flex-wrap:nowrap;scrollbar-width:none}.nav::-webkit-scrollbar,.summary::-webkit-scrollbar,.sku-buttons::-webkit-scrollbar{display:none}.nav button{flex:0 0 auto;height:34px;padding:0 13px;border-radius:999px;font-size:13px}
      .summary{display:flex;gap:8px;overflow-x:auto;margin:10px auto 6px;padding:0 12px}.metric{flex:0 0 112px;padding:9px 10px;border-radius:8px}.metric strong{font-size:18px}.metric span{font-size:11px}
      .grid{display:flex;flex-direction:column;padding:8px 10px 26px;gap:12px}.card{border-radius:8px;box-shadow:0 8px 22px rgba(20,34,44,.08)}.photo{aspect-ratio:1/1}.body{padding:12px;gap:9px}.cat{font-size:12px}.title{font-size:14px;line-height:1.45;min-height:0}.sku{font-size:12px;padding:8px;line-height:1.5}.price{font-size:22px}.status{font-size:11px;line-height:1.4}
      .sku-buttons{max-height:none;overflow-x:auto;flex-wrap:nowrap;margin-right:-12px;padding:0 12px 2px 0}.sku-btn{flex:0 0 auto;max-width:188px;min-height:38px;padding:8px 10px;font-size:12px}.buy{width:100%;height:42px;border-radius:8px}.detail-block{max-height:360px}.kv,.pkg{font-size:11px}.kv th,.kv td,.pkg th,.pkg td{padding:7px}.kv th{width:34%}
    }
    @media(max-width:380px){.grid{padding-left:8px;padding-right:8px}.sku-btn{max-width:164px}.title{font-size:13px}.price{font-size:21px}}
    </style>
</head>
