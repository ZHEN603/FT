271230/sku_6_墨绿色植绒经典款_001_7b0a8db10c.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "淡绿植绒经典款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_3_淡绿植绒经典款_001_02f36e3bcc.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "灰色半圆款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_9_灰色半圆款_001_a47994e4d0.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "灰色植绒经典款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_2_灰色植绒经典款_001_e8e3978b6e.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "灰色植绒透光款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_13_灰色植绒透光款_001_8305d72489.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "米白植绒经典款（如图有logo）", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_15_米白植绒经典款（如图有logo）_001_3c72185c44.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "1600x1600"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "米白色半圆款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_8_米白色半圆款_001_29147fadfd.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "米白色植绒经典款", "price": 0.65, "priceStatus": "页面当前选中SKU价格", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_1_米白色植绒经典款_001_110b7bc741.webp", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "米白色植绒透光款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_12_米白色植绒透光款_001_75e6ae9832.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "粉色半圆款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_10_粉色半圆款_001_ed0f0d1d62.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "粉色植绒经典款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_4_粉色植绒经典款_001_b643b395dd.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "粉色植绒透光款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_14_粉色植绒透光款_001_955cf7279e.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "黄色植绒经典款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_5_黄色植绒经典款_001_d9f27b052a.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "黑色半圆款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_11_黑色半圆款_001_b679b78443.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}, {"skuBody": "规格:植绒防滑不掉绒", "skuColor": "黑色植绒经典款", "price": 0.65, "priceStatus": "规格价格适用于颜色SKU", "rankPrice": 0.65, "image": "assets/植绒衣架/637679271230/sku_7_黑色植绒经典款_001_635366e32a.jpg", "imageMatch": "SKU按钮同源高清图", "imageSize": "800x800"}]}];
  const grid = document.getElementById('grid');
  const money = value => value === '' || value === null ? '价格待核' : '¥' + Number(value).toFixed(2);
  const esc = value => String(value ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
  function attrTable(attrs) {
    if (!attrs.length) return '<div class="note">页面未提取到商品属性</div>';
    return `<table class="kv"><tbody>${attrs.map(x=>`<tr><th>${esc(x.name)}</th><td>${esc(x.value)}</td></tr>`).join('')}</tbody></table>`;
  }
  function packageTable(packaging) {
    if (!packaging.headers?.length || !packaging.rows?.length) return '<div class="note">页面未提供明确包装信息</div>';
    return `<table class="pkg"><thead><tr>${packaging.headers.map(h=>`<th>${esc(h)}</th>`).join('')}</tr></thead><tbody>${packaging.rows.map(r=>`<tr>${r.map(c=>`<td>${esc(c)}</td>`).join('')}</tr>`).join('')}</tbody></table>`;
  }
  function optionLabel(option) {
    return option.skuColor || option.skuBody || '默认SKU';
  }
  function statusText(option) {
    const ref = option.price === '' && option.rankPrice !== '' ? `，排序参考价 ¥${Number(option.rankPrice).toFixed(2)}` : '';
    return `${option.priceStatus || ''}${ref}`;
  }
  function render(cat='全部') {
    const visible = products
      .map((p, productIndex) => ({ p, productIndex }))
      .filter(x => cat === '全部' || x.p.category === cat);
    grid.innerHTML = visible.map(({ p, productIndex }) => {
      const active = p.options[0] || {};
      const activeImage = active.image || p.mainImage;
      return `
      <article class="card" data-category="${esc(p.category)}" data-index="${productIndex}">
        <div class="photo"><img loading="lazy" src="${esc(activeImage)}" alt="${esc(p.title)}"></div>
        <div class="body">
          <div class="cat">${esc(p.category)} · ${p.options.length} 个SKU</div>
          <div class="title">${esc(p.title)}</div>
          <div class="sku" data-role="sku">${esc(active.skuBody)}<br>${esc(active.skuColor)}</div>
          <div class="price" data-role="price">${money(active.price)}</div>
          <div class="status" data-role="status">${esc(statusText(active))}</div>
          <div class="sku-buttons">${p.options.map((o,i)=>`<button class="sku-btn ${i===0?'active':''}" data-product="${productIndex}" data-option="${i}" title="${esc(o.imageMatch)} ${esc(o.imageSize)}">${esc(optionLabel(o))}</button>`).join('')}</div>
          <details><summary>产品详情</summary><div class="detail-block"><h4>商品属性</h4>${attrTable(p.attrs)}<h4>包装信息</h4>${packageTable(p.packaging)}</div></details>
          <a class="buy" href="${esc(p.link)}" target="_blank" rel="noopener">1688购买</a>
        </div>
      </article>`; }).join('');
  }
  document.querySelector('.nav').addEventListener('click', e => {
    if (!e.target.matches('button')) return;
    document.querySelectorAll('.nav button').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
    e.target.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'smooth' });
    render(e.target.dataset.cat);
  });
  grid.addEventListener('click', e => {
    const btn = e.target.closest('.sku-btn');
    if (!btn) return;
    const card = btn.closest('.card');
    const product = products[Number(btn.dataset.product)];
    const option = product.options[Number(btn.dataset.option)];
    card.querySelectorAll('.sku-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    card.querySelector('[data-role="sku"]').innerHTML = `${esc(option.skuBody)}<br>${esc(option.skuColor)}`;
    card.querySelector('[data-role="price"]').textContent = money(option.price);
    card.querySelector('[data-role="status"]').textContent = statusText(option);
    const img = card.querySelector('.photo img');
    img.style.opacity = .25;
    setTimeout(() => { img.src = option.image || product.mainImage; img.style.opacity = 1; }, 120);
  });
  render();
  </script>
</body>
</html>