DATABASE_URL=postgresql://ft_user:ft_password@localhost:5432/ft_dev

# Required only when the users table is empty on first startup.
# In production, set these explicitly instead of relying on development defaults.
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_DISPLAY_NAME=
ADMIN_BOOTSTRAP_WHATSAPP=

# Optional: enables AI translation for admin/customer WhatsApp conversations.
# Without this key, the app uses a local development fallback so messaging still works.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
